rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || (request.auth.token.email == "mohakatsosane@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'hospital', 'donor'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'donor' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /donors/{donorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isOwner(donorId) || isAdmin() || hasRole('hospital'));
    }

    match /hospitals/{hospitalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isOwner(hospitalId) && hasRole('hospital'));
    }

    match /inventory/{unitId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hospital') || isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hospital') || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.recipientId || isAdmin());
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.donorId || hasRole('hospital') || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.donorId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.donorId || hasRole('hospital') || isAdmin());
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.donorId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.recipientId || isAdmin()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }
    
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
